<Window
    x:Class="AiAdminUi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:AiAdminUi"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="AI Admin UI"
    Width="1000"
    Height="903"
    Background="{StaticResource WindowBackgroundBrush}"
    Foreground="{StaticResource TextBrush}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Window.Resources>
        <!--  Global style to make disabled buttons much more obvious in Dark Theme  -->
        <Style BasedOn="{StaticResource {x:Type Button}}" TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </Trigger>
                <!--  Tactile feedback: Shrink slightly and dim more aggressively on click  -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.5" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.97" ScaleY="0.97" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!--  Specific feedback for Primary Buttons (Save/Execute)  -->
        <Style
            x:Key="PrimaryButton"
            BasedOn="{StaticResource PrimaryButton}"
            TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Style.Triggers>
                <!--  Dirty state: Highlight the button to indicate unsaved changes  -->
                <Trigger Property="Tag" Value="Dirty">
                    <Setter Property="Background" Value="#FF840000" />
                    <Setter Property="Foreground" Value="#212121" />
                </Trigger>
                <!--  Tactile feedback: Shrink and slightly dim on click  -->
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.7" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.96" ScaleY="0.96" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock
                    FontSize="28"
                    FontWeight="Light"
                    Text="AI Admin UI" />
                <TextBlock
                    x:Name="txtVersion"
                    Margin="10,0,0,3"
                    VerticalAlignment="Bottom"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource SecondaryTextBrush}"
                    Text="v1.6" />
            </StackPanel>
            <TextBlock
                FontSize="13"
                Foreground="{StaticResource SecondaryTextBrush}"
                Text="Configuration management for server auto-spawn settings" />
        </StackPanel>

        <TabControl Grid.Row="1">
            <TabItem Header="Configuration">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Performance Info Box  -->
                        <Border
                            Grid.Row="0"
                            Margin="0,0,0,8"
                            Padding="10"
                            Background="#1E3A5F"
                            BorderBrush="#4A90E2"
                            BorderThickness="1"
                            CornerRadius="4">
                            <StackPanel>
                                <TextBlock
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="#4A90E2"
                                    Text="⚡ Performance Optimizations" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="11"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap">
                                    <Run Text="Fully optimized for high-population servers (400+ players):" /><LineBreak />
                                    <Run Text="• Thread-safe operation with mutex-protected global state" /><LineBreak />
                                    <Run Text="• ProcessEvent hot path optimized (99.9% reduction in allocations)" /><LineBreak />
                                    <Run Text="• O(1) hash map lookups for all player/spawn data" /><LineBreak />
                                    <Run Text="• Throttled operations (4Hz max) to prevent overhead" /><LineBreak />
                                    <Run Text="• Smart locking strategy minimizes contention" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <GroupBox
                            Grid.Row="1"
                            Padding="10"
                            BorderBrush="Red"
                            Header="Auto Spawn">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                x:Name="chkAutoSpawnEnabled"
                                Grid.Row="0"
                                Grid.ColumnSpan="3"
                                Margin="0,0,0,8"
                                Content="Enabled">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Auto-Spawn System</Bold><LineBreak/>
                                        When enabled, automatically spawns AI dinos near players based on species rules below.<LineBreak/><LineBreak/>
                                        <Bold>How it works:</Bold> Every interval, picks a random player and spawns AI within radius limits, respecting max counts per species.<LineBreak/><LineBreak/>
                                        <Bold>Corpse Mode:</Bold> If "Spawn corpses instead of live AI" is enabled below, this will spawn gore only (no live AI).<LineBreak/><LineBreak/>
                                        <Bold>Single Corpse Tip:</Bold> To spawn just one corpse, enable Corpse Mode and set that species Max Count to 1 in Auto Spawn Rules.<LineBreak/><LineBreak/>
                                        <Bold>Performance:</Bold> Fully thread-safe and optimized for high-population servers (tested for 400+ players).<LineBreak/><LineBreak/>
                                        <Bold>Tip:</Bold> Start with a longer interval (3-5 min) and adjust based on server performance.
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Interval (min)" />
                                <TextBox
                                x:Name="txtIntervalMs"
                                Grid.Row="1"
                                Grid.Column="2"
                                Height="26"
                                VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Auto-Spawn Interval</Bold><LineBreak/>
                                        How often the auto-spawn system attempts to spawn new AI dinos.<LineBreak/><LineBreak/>
                                        <Bold>Format:</Bold> Minutes (decimals allowed)<LineBreak/>
                                        • 3.0 = 3 minutes (default, recommended)<LineBreak/>
                                        • 0.5 = 30 seconds (more frequent)<LineBreak/>
                                        • 5.0 = 5 minutes (less frequent)<LineBreak/><LineBreak/>
                                        <Bold>Performance:</Bold> Thread-safe operation with optimized locking strategy. Lower values = more AI but higher server load. System runs at 4Hz max (throttled) to prevent overhead.<LineBreak/><LineBreak/>
                                        <Bold>High Player Count:</Bold> Safe for 400+ player servers. Monitor FPS when adjusting.
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Min Player Distance" />
                                <TextBox
                                x:Name="txtMinPlayerDistance"
                                Grid.Row="2"
                                Grid.Column="2"
                                Height="26"
                                VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Minimum Player Distance (Auto-Spawn)</Bold><LineBreak/>
                                        AI will NOT spawn closer than this distance to ANY player.<LineBreak/><LineBreak/>
                                        <Bold>Units:</Bold> Unreal units (100 = 1 meter)<LineBreak/>
                                        • 900 = 9 meters (default, recommended)<LineBreak/>
                                        • 500 = 5 meters (spawns closer, more encounters)<LineBreak/>
                                        • 1500 = 15 meters (spawns farther, safer)<LineBreak/><LineBreak/>
                                        <Bold>Note:</Bold> System checks distance to ALL online players, not just the target player. Prevents surprise spawns on top of players.
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Max Spawn Attempts" />
                                <TextBox
                                x:Name="txtMaxSpawnAttempts"
                                Grid.Row="3"
                                Grid.Column="2"
                                Height="26"
                                VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Max Spawn Attempts</Bold><LineBreak/>
                                        How many random locations to try before giving up on spawning.<LineBreak/><LineBreak/>
                                        <Bold>Process:</Bold> For each attempt:<LineBreak/>
                                        1. Pick random point within radius<LineBreak/>
                                        2. Trace to ground (snap to terrain)<LineBreak/>
                                        3. Check distance from all players<LineBreak/>
                                        4. If valid → spawn, else retry<LineBreak/><LineBreak/>
                                        <Bold>Recommended:</Bold> 6 (default)<LineBreak/>
                                        • Lower = faster but more failed spawns<LineBreak/>
                                        • Higher = more reliable but slight performance cost<LineBreak/><LineBreak/>
                                        <Bold>Note:</Bold> Enable "Debug Spawning" to see each attempt in detail.
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <CheckBox
                                x:Name="chkAutoSpawnCorpseOnly"
                                Grid.Row="4"
                                Grid.ColumnSpan="3"
                                Margin="0,8,0,0"
                                Content="Spawn corpses instead of live AI (best performance)">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Performance Mode</Bold><LineBreak/>
                                        Spawns a gore/corpse actor instead of a live AI dino. This avoids AI ticks and is much lighter on server FPS.<LineBreak/><LineBreak/>
                                        <Bold>Tip:</Bold> Set the corpse class below to customize what gets spawned.<LineBreak/>
                                        <Bold>Single Corpse:</Bold> Enable this and set the species Max Count to 1 in Auto Spawn Rules.
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock
                                Grid.Row="5"
                                Grid.Column="0"
                                Margin="0,5,0,0"
                                VerticalAlignment="Center"
                                Text="Corpse Class" />
                                <TextBox
                                x:Name="txtAutoSpawnCorpseClass"
                                Grid.Row="5"
                                Grid.Column="2"
                                Height="26"
                                VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Corpse/Gore Class</Bold><LineBreak/>
                                        Class name or full path for the gore/food actor to spawn.<LineBreak/><LineBreak/>
                                        <Bold>Default:</Bold> dead_dino (spawns a dead dino at the location)<LineBreak/>
                                        <Bold>Example:</Bold> BP_SchoolFishGore_Base_C or /Game/.../BP_PieceOfMeat.BP_PieceOfMeat_C
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <TextBlock
                                Grid.Row="6"
                                Grid.Column="0"
                                Margin="0,5,0,0"
                                VerticalAlignment="Center"
                                Text="Corpse Scale" />
                                <TextBox
                                x:Name="txtAutoSpawnCorpseScale"
                                Grid.Row="6"
                                Grid.Column="2"
                                Height="26"
                                VerticalContentAlignment="Center">
                                    <TextBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Corpse Scale</Bold><LineBreak/>
                                        Scales the spawned gore actor. Lower values are smaller and more natural.<LineBreak/><LineBreak/>
                                        <Bold>Default:</Bold> 0.25 (recommended)<LineBreak/>
                                        <Bold>Range:</Bold> 0.05 to 2.0
                                        </TextBlock>
                                    </TextBox.ToolTip>
                                </TextBox>

                                <TextBlock
                                Grid.Row="7"
                                Grid.Column="0"
                                Margin="0,5,0,0"
                                VerticalAlignment="Center"
                                Text="Auto Spawn Loop" />
                                <Button
                                x:Name="btnToggleAuto"
                                Grid.Row="7"
                                Grid.Column="2"
                                Width="140"
                                Margin="0,10,0,0"
                                Click="btnToggleAuto_Click"
                                Cursor="Hand">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                        x:Name="iconToggleAuto"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource FluentIcon}"
                                        Text="&#xE768;" />
                                        <TextBlock
                                        x:Name="txtToggleAuto"
                                        VerticalAlignment="Center"
                                        Text="Start Auto" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </GroupBox>
                        <GroupBox
                            Grid.Row="2"
                            Margin="0,8,0,0"
                            Padding="10"
                            Header="Auto Spawn Rules (Max Count)"
                            ToolTip="Per-species cap for auto-spawn. To spawn a single corpse, set that species Max Count to 1 and enable Corpse Mode above.">
                            <DataGrid
                                x:Name="rulesGrid"
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                CanUserDeleteRows="False"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                                ToolTip="Per-species maximum counts for auto-spawn">
                                <DataGrid.Columns>
                                    <DataGridTextColumn
                                        Width="*"
                                        Binding="{Binding Species}"
                                        Header="Species"
                                        IsReadOnly="True" />
                                    <DataGridTextColumn
                                        Width="120"
                                        Binding="{Binding Max}"
                                        Header="Max" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <GroupBox
                            Grid.Row="0"
                            Margin="8,0,0,0"
                            Padding="10"
                            Header="Auto Refresh Config">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <CheckBox
                                    x:Name="chkAutoReloadEnabled"
                                    Grid.Row="0"
                                    Grid.ColumnSpan="3"
                                    Margin="0,0,0,8"
                                    Content="Enabled"
                                    ToolTip="Automatically refresh the config file when it changes" />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="Interval (min)" />
                                <TextBox
                                    x:Name="txtAutoReloadIntervalMs"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Height="26"
                                    VerticalContentAlignment="Center"
                                    ToolTip="How often to check for config changes in minutes (decimals allowed, e.g. 0.5 = 30s)" />
                            </Grid>
                        </GroupBox>

                        <GroupBox
                            Grid.Row="1"
                            Margin="8,8,0,0"
                            Padding="10"
                            Header="General Settings">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="Debug Logs (Master)" />
                                <CheckBox
                                    x:Name="chkDebugLogsEnabled"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    VerticalAlignment="Center">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                            <Bold>Master Debug Switch</Bold><LineBreak/>
                                            Must be enabled for any category-specific debug logs to work.<LineBreak/><LineBreak/>
                                            <Bold>Performance:</Bold> All debug logging is thread-safe with minimal performance impact. Uses optimized mutex locks to prevent race conditions on high-population servers.<LineBreak/><LineBreak/>
                                            <Bold>Note:</Bold> Debug categories have granular controls below - enable only what you need for troubleshooting.
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="Spawn Log" />
                                <CheckBox
                                    x:Name="chkSpawnLogEnabled"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                            <Bold>Spawn Log (Production Feature)</Bold><LineBreak/>
                                            Logs each successful spawn with a clean message.<LineBreak/><LineBreak/>
                                            <Bold>Example output:</Bold><LineBreak/>
                                            "Spawned Carnotaurus via auto at (1234.5, 6789.0, 100.0)"<LineBreak/><LineBreak/>
                                            <Bold>Use for:</Bold> Monitoring what AI is spawning on your server<LineBreak/><LineBreak/>
                                            <Bold>Difference from "Debug Spawning":</Bold><LineBreak/>
                                            • Spawn Log = 1 line per success (clean, production-ready)<LineBreak/>
                                            • Debug Spawning = 5-15 lines per attempt (verbose troubleshooting)<LineBreak/><LineBreak/>
                                            <Bold>Recommended:</Bold> Leave enabled for server monitoring. Safe for production.
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="Apply Spawn Growth" />
                                <CheckBox
                                    x:Name="chkSpawnApplyGrowth"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    ToolTip="Force spawned AI dinos to a specific growth value" />

                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="Spawn Growth (0-1)" />
                                <TextBox
                                    x:Name="txtSpawnGrowth"
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    Height="26"
                                    Margin="0,8,0,0"
                                    VerticalContentAlignment="Center"
                                    ToolTip="Growth applied on spawn (0.0 juvenile - 1.0 adult)" />
                            </Grid>
                        </GroupBox>

                        <GroupBox
                            Grid.Row="2"
                            Margin="8,8,0,0"
                            Padding="10"
                            Header="Player Settings">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="Player Sync (min)"
                                    ToolTip="Player Detector" />
                                <TextBox
                                    x:Name="txtPlayerSyncIntervalMs"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    Height="26"
                                    VerticalContentAlignment="Center"
                                    BorderBrush="Red"
                                    ToolTip="Fallback player list refresh interval in minutes (decimals allowed). Lower values update PlayerIDs faster but add load on the server." />

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="Players Write (min)"
                                    ToolTip="Player writer interval" />
                                <TextBox
                                    x:Name="txtPlayersWriteIntervalMs"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Height="26"
                                    Margin="0,8,0,0"
                                    VerticalContentAlignment="Center"
                                    ToolTip="How often the server writes the player list file (decimals allowed). Lower values update PlayerIDs faster but add file I/O." />
                            </Grid>
                        </GroupBox>

                        <Expander
                            Grid.Row="3"
                            Margin="8,8,0,0"
                            Padding="10"
                            Header="Debug Categories (requires master debug enabled)"
                            IsExpanded="False">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Text="Log Parsing" />
                                <CheckBox
                                    x:Name="chkDebugLogParsing"
                                    Grid.Row="0"
                                    Grid.Column="2"
                                    VerticalAlignment="Center">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                            <Bold>Log File Parsing Debug</Bold><LineBreak/>
                                            Shows: File size, read position, lines processed, Steam ID extraction, player cache contents<LineBreak/><LineBreak/>
                                            <Bold>Use when:</Bold> Chat commands not recognizing admins, Steam ID lookup failing<LineBreak/><LineBreak/>
                                            <Bold>Example output:</Bold><LineBreak/>
                                            "Log parsing: Found player 'sibercat' -> SteamID 76561197993213308"<LineBreak/>
                                            "Cache now has 3 entries"<LineBreak/><LineBreak/>
                                            <Bold>Performance:</Bold> Thread-safe with mutex-protected cache updates. Minimal lock duration by collecting updates locally first.
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="Chat Commands" />
                                <CheckBox
                                    x:Name="chkDebugChatCommands"
                                    Grid.Row="1"
                                    Grid.Column="2"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                            <Bold>Chat Command Processing Debug</Bold><LineBreak/>
                                            Shows: Command detection, player lookup, admin verification, command execution<LineBreak/><LineBreak/>
                                            <Bold>Use when:</Bold> /ai commands not working, admin auth issues<LineBreak/><LineBreak/>
                                            <Bold>Example output:</Bold><LineBreak/>
                                            "[CHAT] Command line: ai start"<LineBreak/>
                                            "[CHAT] Player: Sibercat (SteamID: 76561197993213308)"<LineBreak/>
                                            "[CHAT] Admin check passed"<LineBreak/><LineBreak/>
                                            <Bold>Performance:</Bold> Optimized hot path with function pointer caching (eliminates 99.9% of string allocations). Thread-safe player name lookups.
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock
                                    Grid.Row="2"
                                    Grid.Column="0"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="Spawning" />
                                <CheckBox
                                    x:Name="chkDebugSpawning"
                                    Grid.Row="2"
                                    Grid.Column="2"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                            <Bold>Spawn Process Debug (Very Verbose!)</Bold><LineBreak/>
                                            Shows: Rule checks, capacity limits, each spawn attempt (1-6), ground trace results, player distance checks, success/failure reasons<LineBreak/><LineBreak/>
                                            <Bold>Use when:</Bold> AI not spawning, spawn failures, location issues<LineBreak/><LineBreak/>
                                            <Bold>Example output:</Bold><LineBreak/>
                                            "carno: Attempting spawn (2/4)"<LineBreak/>
                                            "FindSpawnLocation: Attempt 3/6"<LineBreak/>
                                            "Trace succeeded, snapped=(1234,5678,90)"<LineBreak/>
                                            "SUCCESS: Location found far from players"<LineBreak/><LineBreak/>
                                            <Bold>Note:</Bold> Different from "Spawn Log" which only shows successful spawns. This shows ALL attempts and failures.
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock
                                    Grid.Row="3"
                                    Grid.Column="0"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="Config" />
                                <CheckBox
                                    x:Name="chkDebugConfig"
                                    Grid.Row="3"
                                    Grid.Column="2"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                            <Bold>Config File Debug</Bold><LineBreak/>
                                            Shows: Config reload events, changed settings, file write times<LineBreak/><LineBreak/>
                                            <Bold>Use when:</Bold> Config changes not applying, auto-reload issues<LineBreak/><LineBreak/>
                                            <Bold>Example output:</Bold><LineBreak/>
                                            "[+] Config reloaded. players_write_interval_ms=15000"<LineBreak/><LineBreak/>
                                            <Bold>Performance:</Bold> Thread-safe atomic config reloads. File I/O done outside locks to prevent blocking other threads.
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                <TextBlock
                                    Grid.Row="4"
                                    Grid.Column="0"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center"
                                    Text="Command Queue" />
                                <CheckBox
                                    x:Name="chkDebugCommandQueue"
                                    Grid.Row="4"
                                    Grid.Column="2"
                                    Margin="0,8,0,0"
                                    VerticalAlignment="Center">
                                    <CheckBox.ToolTip>
                                        <TextBlock MaxWidth="400" TextWrapping="Wrap">
                                            <Bold>Command Queue Processing Debug</Bold><LineBreak/>
                                            Shows: Command file reads, queue processing, command execution<LineBreak/><LineBreak/>
                                            <Bold>Use when:</Bold> Admin UI commands not executing, queue file issues<LineBreak/><LineBreak/>
                                            <Bold>Note:</Bold> Currently no debug logs implemented for command queue (reserved for future use)
                                        </TextBlock>
                                    </CheckBox.ToolTip>
                                </CheckBox>

                                                            </Grid>
                        </Expander>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Fish Respawn">
                <GroupBox
                    Margin="8"
                    Padding="10"
                    Header="Fish Respawn Settings">
                    <StackPanel>
                        <!--  Info Banner  -->
                        <Border
                            Margin="0,0,0,12"
                            Padding="10"
                            Background="#1E3A5F"
                            BorderBrush="#4A90E2"
                            BorderThickness="1"
                            CornerRadius="4">
                            <StackPanel>
                                <TextBlock
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="#4A90E2"
                                    Text="🐟 Automatic Fish Respawn System" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="10.5"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap">
                                    <Run Text="Keep water bodies stocked with fish for high-population servers." /><LineBreak />
                                    <Run Text="• Manual Command: /ai fish respawn" /><LineBreak />
                                    <Run Text="• Automatic Timer: Enable below for hands-free operation" />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!--  Enable Fish Respawn  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox
                                x:Name="chkFishRespawnEnabled"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Content="Auto Fish Respawn Enabled"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                                <CheckBox.ToolTip>
                                    <TextBlock MaxWidth="400" TextWrapping="Wrap">
                                        <Bold>Enable Automatic Fish Respawn</Bold><LineBreak />
                                        When enabled, fish schools will automatically respawn at the configured interval.<LineBreak /><LineBreak />
                                        <Bold>How it works:</Bold><LineBreak />
                                        • Destroys existing fish schools (they respawn naturally)<LineBreak />
                                        • Runs on a timer (default: every 5 minutes)<LineBreak />
                                        • Can optionally skip fish near players to avoid visual glitches<LineBreak /><LineBreak />
                                        <Bold>Performance:</Bold> Minimal impact - only runs every few minutes.
                                    </TextBlock>
                                </CheckBox.ToolTip>
                            </CheckBox>

                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Text="Automatically respawn fish on a timer" />
                        </Grid>

                        <!--  Fish Respawn Interval  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Respawn Interval (seconds):"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                                <TextBlock.ToolTip>
                                    <TextBlock MaxWidth="400" TextWrapping="Wrap">
                                        <Bold>Fish Respawn Interval</Bold><LineBreak />
                                        How often to automatically respawn fish schools.<LineBreak /><LineBreak />
                                        <Bold>Recommended Values:</Bold><LineBreak />
                                        • 300s (5 min) - Default, good for most servers<LineBreak />
                                        • 180s (3 min) - High player count servers<LineBreak />
                                        • 600s (10 min) - Low player count or RP servers<LineBreak /><LineBreak />
                                        <Bold>Minimum:</Bold> 10 seconds (not recommended - use higher values)
                                    </TextBlock>
                                </TextBlock.ToolTip>
                            </TextBlock>

                            <TextBox
                                x:Name="txtFishRespawnInterval"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="300" />

                            <TextBlock
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Text="(Default: 300s = 5 minutes)" />
                        </Grid>

                        <!--  Only Respawn Far From Players  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <CheckBox
                                x:Name="chkFishRespawnOnlyFar"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Content="Only Respawn Far From Players"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                                <CheckBox.ToolTip>
                                    <TextBlock MaxWidth="400" TextWrapping="Wrap">
                                        <Bold>Respawn Only Far From Players</Bold><LineBreak />
                                        When enabled, fish schools near players are skipped during respawn.<LineBreak /><LineBreak />
                                        <Bold>Why use this:</Bold><LineBreak />
                                        • Prevents fish "popping" in/out near players<LineBreak />
                                        • More immersive experience<LineBreak />
                                        • Fish that players are actively hunting stay intact<LineBreak /><LineBreak />
                                        <Bold>When to disable:</Bold><LineBreak />
                                        • If you want ALL fish to respawn regardless of player proximity<LineBreak />
                                        • Testing/debugging purposes<LineBreak /><LineBreak />
                                        <Bold>Recommended:</Bold> Keep ENABLED for normal gameplay.
                                    </TextBlock>
                                </CheckBox.ToolTip>
                            </CheckBox>

                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Text="Skip fish near players (recommended)" />
                        </Grid>

                        <!--  Min Player Distance  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Min Player Distance (cm):"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                                <TextBlock.ToolTip>
                                    <TextBlock MaxWidth="400" TextWrapping="Wrap">
                                        <Bold>Minimum Player Distance</Bold><LineBreak />
                                        Fish schools within this distance from ANY player will be skipped during respawn.<LineBreak /><LineBreak />
                                        Only applies when "Only Respawn Far From Players" is enabled.<LineBreak /><LineBreak />
                                        <Bold>Recommended Values:</Bold><LineBreak />
                                        • 3000cm (30m) - Default, good balance<LineBreak />
                                        • 5000cm (50m) - More conservative<LineBreak />
                                        • 1500cm (15m) - Aggressive respawning<LineBreak /><LineBreak />
                                        <Bold>Note:</Bold> 100cm = 1 meter in Unreal Engine
                                    </TextBlock>
                                </TextBlock.ToolTip>
                            </TextBlock>

                            <TextBox
                                x:Name="txtFishRespawnMinDistance"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="3000" />

                            <TextBlock
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Text="(Default: 3000cm = 30 meters)" />
                        </Grid>

                        <!--  Fish Amount Override  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Fish Amount (optional):"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                                <TextBlock.ToolTip>
                                    <TextBlock MaxWidth="420" TextWrapping="Wrap">
                                        <Bold>Fish Amount Override</Bold><LineBreak />
                                        Set how many fish each school contains when respawned.<LineBreak /><LineBreak />
                                        <Bold>Leave blank:</Bold> Uses the default configured by the game.<LineBreak />
                                        <Bold>Set to 0:</Bold> Empty school (no fish).<LineBreak /><LineBreak />
                                        <Bold>Example:</Bold> 8
                                    </TextBlock>
                                </TextBlock.ToolTip>
                            </TextBlock>

                            <TextBox
                                x:Name="txtFishRespawnAmount"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                ToolTip="Optional fish amount override" />

                            <TextBlock
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Text="Leave blank for default" />
                        </Grid>

                        <!--  Fish To Spawn Override  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="260" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="Fish To Spawn (optional):"
                                ToolTipService.InitialShowDelay="200"
                                ToolTipService.ShowDuration="30000">
                                <TextBlock.ToolTip>
                                    <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Fish To Spawn Override</Bold><LineBreak />
                                        Set a specific fish class to spawn for all schools.<LineBreak /><LineBreak />
                                        <Bold>Accepted:</Bold> Short class name or full path.<LineBreak />
                                        <Bold>Example:</Bold> BP_Fish_School_Gore_C
                                    </TextBlock>
                                </TextBlock.ToolTip>
                            </TextBlock>

                            <TextBox
                                x:Name="txtFishRespawnFishToSpawn"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                ToolTip="Optional fish class to spawn" />

                            <TextBlock
                                Grid.Column="2"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                Text="Leave blank for default" />
                        </Grid>

                        <!--  Manual Respawn Button  -->
                        <Button
                            x:Name="btnManualFishRespawn"
                            Height="45"
                            Margin="0,12,0,0"
                            Padding="12,8"
                            HorizontalAlignment="Stretch"
                            Background="#1E5A3D"
                            BorderBrush="#2E8B57"
                            BorderThickness="1"
                            Click="btnManualFishRespawn_Click"
                            ToolTipService.InitialShowDelay="200"
                            ToolTipService.ShowDuration="30000">
                            <Button.ToolTip>
                                <TextBlock MaxWidth="400" TextWrapping="Wrap">
                                    <Bold>Manual Fish Respawn (Admin UI)</Bold><LineBreak />
                                    Click to immediately trigger fish respawn from the Admin UI.<LineBreak /><LineBreak />
                                    <Bold>Benefits:</Bold><LineBreak />
                                    • No need to be in-game<LineBreak />
                                    • Respects current settings (distance, visualization)<LineBreak />
                                    • Works exactly like the /ai fish respawn command<LineBreak /><LineBreak />
                                    <Bold>Server must be running for this to work.</Bold>
                                </TextBlock>
                            </Button.ToolTip>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    Margin="0,0,10,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Segoe MDL2 Assets"
                                    FontSize="18"
                                    Foreground="#4AE290"
                                    Text="&#xE72C;" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="White"
                                        Text="Manual Fish Respawn" />
                                    <TextBlock
                                        FontSize="10"
                                        Foreground="#B0E0C9"
                                        Text="Trigger fish respawn now from Admin UI" />
                                </StackPanel>
                            </StackPanel>
                        </Button>

                        <!--  Manual Command Info  -->
                        <Border
                            Margin="0,12,0,0"
                            Padding="10"
                            Background="#2C2C2C"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <StackPanel>
                                <TextBlock
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    Text="In-Game Chat Command (Alternative)" />
                                <TextBlock
                                    Margin="0,6,0,0"
                                    FontFamily="Consolas"
                                    FontSize="10.5"
                                    Foreground="#4A90E2"
                                    Text="/ai fish respawn" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="10"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap"
                                    Text="Use this in-game chat command to manually trigger fish respawn. Works the same as the button above." />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </GroupBox>
            </TabItem>

            <TabItem Header="Hunger Corpse">
                <GroupBox
                    Margin="8"
                    Padding="10"
                    Header="Hunger-Based Corpse Spawning">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!--  Description  -->
                            <TextBlock
                                Margin="0,0,0,15"
                                FontSize="11.5"
                                Foreground="{StaticResource SecondaryTextBrush}"
                                TextWrapping="Wrap"
                                Text="Automatically spawn corpses near carnivore players when their hunger drops below the configured threshold." />

                            <!--  Enable/Disable  -->
                            <CheckBox
                                x:Name="chkHungerCorpseEnabled"
                                Margin="0,0,0,15"
                                Content="Enable Hunger-Based Corpse Spawning"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextBrush}" />

                            <!--  General Settings  -->
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="11.5"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextBrush}"
                                Text="General Settings" />

                            <CheckBox
                                x:Name="chkHungerCorpseCarnivoreOnly"
                                Margin="0,0,0,8"
                                Content="Carnivores Only (skip herbivores)"
                                FontSize="11"
                                Foreground="{StaticResource TextBrush}"
                                IsChecked="True" />

                            <CheckBox
                                x:Name="chkHungerCorpseMatchSize"
                                Margin="0,0,0,15"
                                Content="Match Player Size (corpse growth = player growth)"
                                FontSize="11"
                                Foreground="{StaticResource TextBrush}"
                                IsChecked="True" />

                            <!--  Hunger Threshold  -->
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="11.5"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextBrush}"
                                Text="Hunger Threshold" />

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextBrush}"
                                    Text="Hunger Threshold (%):" />
                                <TextBox
                                    x:Name="txtHungerCorpseThreshold"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Text="20.0"
                                    TextAlignment="Right"
                                    ToolTip="Percentage (0-100). Default: 20%" />
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontStyle="Italic"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    Text="Recommended: 15-25%" />
                            </Grid>

                            <!--  Cooldown Settings  -->
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="11.5"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextBrush}"
                                Text="Cooldown Settings" />

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextBrush}"
                                    Text="Cooldown (minutes):" />
                                <TextBox
                                    x:Name="txtHungerCorpseCooldown"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Text="5"
                                    TextAlignment="Right"
                                    ToolTip="Minutes between spawns per player. Default: 5" />
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontStyle="Italic"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    Text="Recommended: 3-10 minutes" />
                            </Grid>

                            <!--  Performance Settings  -->
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="11.5"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextBrush}"
                                Text="Performance Settings" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextBrush}"
                                    Text="Check Interval (sec):" />
                                <TextBox
                                    x:Name="txtHungerCorpseCheckInterval"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Text="5"
                                    TextAlignment="Right"
                                    ToolTip="How often to scan players (seconds). Default: 5. Lower = more responsive but heavier on CPU." />
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontStyle="Italic"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    Text="Recommended: 3-10 seconds" />
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextBrush}"
                                    Text="Max Players / Check:" />
                                <TextBox
                                    x:Name="txtHungerCorpseMaxPlayersPerCheck"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Text="100"
                                    TextAlignment="Right"
                                    ToolTip="Limit players processed per check. 0 = all players. Default: 100." />
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontStyle="Italic"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    Text="Recommended: 50-150 (0 = all)" />
                            </Grid>

                            <!--  Spawn Configuration  -->
                            <TextBlock
                                Margin="0,8,0,8"
                                FontSize="11.5"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource TextBrush}"
                                Text="Spawn Configuration" />

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextBrush}"
                                    Text="Corpse Species:" />
                                <ComboBox
                                    x:Name="cmbHungerCorpseSpecies"
                                    Grid.Column="2"
                                    Height="26"
                                    VerticalAlignment="Center"
                                    ToolTip="Species to spawn (e.g., 'dryosaurus'). Required." />
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextBrush}"
                                    Text="Min Spawn Distance (cm):" />
                                <TextBox
                                    x:Name="txtHungerCorpseRadiusMin"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Text="200"
                                    TextAlignment="Right"
                                    ToolTip="Minimum distance from player (in cm)" />
                                <TextBlock
                                    Grid.Column="3"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="10"
                                    FontStyle="Italic"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    Text="(100 cm = 1 meter)" />
                            </Grid>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    VerticalAlignment="Center"
                                    Foreground="{StaticResource TextBrush}"
                                    Text="Max Spawn Distance (cm):" />
                                <TextBox
                                    x:Name="txtHungerCorpseRadiusMax"
                                    Grid.Column="2"
                                    VerticalAlignment="Center"
                                    Text="600"
                                    TextAlignment="Right"
                                    ToolTip="Maximum distance from player (in cm)" />
                            </Grid>

                            <!--  Info Panel  -->
                            <Border
                                Margin="0,8,0,0"
                                Padding="12"
                                Background="#2C2C2C"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="4">
                                <StackPanel>
                                    <TextBlock
                                        FontSize="11"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource TextBrush}"
                                        Text="How It Works:" />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontSize="10.5"
                                        Foreground="{StaticResource SecondaryTextBrush}"
                                        TextWrapping="Wrap">
                                        • Monitors hunger levels on a configurable interval<LineBreak />
                                        • When hunger drops below threshold, spawns a corpse nearby<LineBreak />
                                        • Per-player cooldown prevents spam and exploitation<LineBreak />
                                        • Scans players in batches (round-robin) to reduce load on large servers<LineBreak />
                                        • Optional per-check player cap for performance on large servers<LineBreak />
                                        • Corpse size matches player's growth for balanced feeding<LineBreak />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </GroupBox>
            </TabItem>

            <TabItem Header="Commands">
                <GroupBox
                    Margin="8"
                    Padding="10"
                    Header="Manual Commands">
                    <StackPanel>
                        <!--  Row 1: Command Execution  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="15" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center" Text="Mode" />
                            <ComboBox
                                x:Name="cmbCommandMode"
                                Grid.Column="2"
                                Height="26"
                                SelectedIndex="0"
                                ToolTip="Command type to execute">
                                <ComboBoxItem Content="spawn_near" />
                                <ComboBoxItem Content="spawn_random" />
                                <ComboBoxItem Content="spawn_at" />
                                <ComboBoxItem Content="spawn_for" />
                                <ComboBoxItem Content="spawn_corpse_for" />
                                <ComboBoxItem Content="despawn" />
                                <ComboBoxItem Content="despawn_all" />
                                <ComboBoxItem Content="kill" />
                                <ComboBoxItem Content="kill_all" />
                            </ComboBox>

                            <TextBlock
                                Grid.Column="4"
                                VerticalAlignment="Center"
                                Text="Species" />
                            <ComboBox
                                x:Name="cmbSpecies"
                                Grid.Column="6"
                                Height="26"
                                ToolTip="Dino species key" />

                            <TextBlock
                                Grid.Column="8"
                                VerticalAlignment="Center"
                                Text="Count" />
                            <TextBox
                                x:Name="txtCount"
                                Grid.Column="10"
                                Height="26"
                                VerticalContentAlignment="Center"
                                Text="1"
                                ToolTip="How many to spawn (max 4)" />

                            <Button
                                x:Name="btnExecute"
                                Grid.Column="12"
                                Width="110"
                                Click="btnExecute_Click"
                                Cursor="Hand"
                                Style="{StaticResource PrimaryButton}"
                                ToolTip="Execute the selected command">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource FluentIcon}"
                                        Text="&#xE768;" />
                                    <TextBlock
                                        x:Name="txtExecuteLabel"
                                        VerticalAlignment="Center"
                                        Text="Execute" />
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!--  Row 2: Parameters  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="150" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center" Text="Coords (x y z)" />
                            <TextBox
                                x:Name="txtCoords"
                                Grid.Column="2"
                                Height="26"
                                VerticalContentAlignment="Center"
                                ToolTip="Used for spawn_at" />

                            <TextBlock
                                Grid.Column="4"
                                VerticalAlignment="Center"
                                Text="Player ID/Name" />
                            <TextBox
                                x:Name="txtPlayerId"
                                Grid.Column="6"
                                Height="26"
                                VerticalContentAlignment="Center"
                                ToolTip="Used for spawn_for / spawn_corpse_for (player id or name)" />
                        </Grid>

                        <!--  Row 3: Players List  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel VerticalAlignment="Top">
                                <TextBlock Text="Players (Write Interval)" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontSize="11"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    Text="Controlled by Players Write (min)"
                                    TextWrapping="Wrap" />
                            </StackPanel>

                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ListView
                                    x:Name="lstPlayers"
                                    Height="90"
                                    SelectionChanged="lstPlayers_SelectionChanged"
                                    ToolTip="Players write interval is controlled by Players Write (min)." />
                                <Button
                                    x:Name="btnRefreshPlayers"
                                    Grid.Column="2"
                                    Width="90"
                                    VerticalAlignment="Top"
                                    Click="btnRefreshPlayers_Click"
                                    Content="Refresh"
                                    ToolTip="Refresh player list" />
                            </Grid>
                        </Grid>

                        <!--  Row 4: RCON  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock VerticalAlignment="Center" Text="RCON (Names &amp; SteamID)" />
                            <TextBox
                                x:Name="txtRconHost"
                                Grid.Column="2"
                                Height="26"
                                VerticalContentAlignment="Center"
                                Text="127.0.0.1"
                                ToolTip="RCON host" Grid.ColumnSpan="3" Margin="20,3,536,3" />
                            <TextBox
                                x:Name="txtRconPort"
                                Grid.Column="4"
                                Height="26"
                                VerticalContentAlignment="Center"
                                Text="8888"
                                ToolTip="RCON port" Margin="50,0,0,0" />
                            <TextBox
                                x:Name="txtRconPass"
                                Grid.Column="6"
                                Height="26"
                                VerticalContentAlignment="Center"
                                ToolTip="RCON password" />
                            <Button
                                x:Name="btnFetchPlayersRcon"
                                Grid.Column="8"
                                Width="90"
                                Click="btnFetchPlayersRcon_Click"
                                Content="Fetch"
                                ToolTip="Fetch player names via RCON" />
                        </Grid>

                        <!--  Row 5: Safe Spawn  -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="Safe Manual Spawn" />
                            <CheckBox
                                x:Name="chkSafeManualSpawn"
                                Grid.Column="2"
                                VerticalAlignment="Center">
                                <CheckBox.ToolTip>
                                    <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                        <Bold>Safe Manual Spawn Mode</Bold><LineBreak/>
                                        Uses relaxed ground-snapping for manual spawns via UI commands.<LineBreak/><LineBreak/>
                                        <Bold>When enabled (recommended):</Bold><LineBreak/>
                                        • Uses 0.65 slope tolerance (more forgiving)<LineBreak/>
                                        • Falls back to Z-offset if trace fails<LineBreak/>
                                        • Prevents spawns falling through world<LineBreak/><LineBreak/>
                                        <Bold>When disabled:</Bold><LineBreak/>
                                        • Uses strict 0.8 slope tolerance<LineBreak/>
                                        • May fail on steep terrain<LineBreak/>
                                        • Only for testing/debugging<LineBreak/><LineBreak/>
                                        <Bold>Note:</Bold> Auto-spawn always uses strict mode for better positioning.
                                    </TextBlock>
                                </CheckBox.ToolTip>
                            </CheckBox>
                        </Grid>

                        <!--  Row 6: Manual Min Distance  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="Manual Min Distance" />
                            <TextBox
                                x:Name="txtManualMinPlayerDistance"
                                Grid.Column="2"
                                Height="26"
                                VerticalContentAlignment="Center"
                                ToolTip="Minimum distance from any player for manual spawns (Unreal units, 100 = 1m)" />
                        </Grid>
                    </StackPanel>
                </GroupBox>
            </TabItem>

            <TabItem Header="Admin">
                <GroupBox
                    Margin="8"
                    Padding="10"
                    Header="Admin Authorization">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Admin Settings  -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="Enable In-Game /ai Commands"
                            ToolTip="Enable or disable in-game /ai chat commands" />
                        <CheckBox
                            x:Name="chkChatCommandsEnabled"
                            Grid.Row="0"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Checked="AdminCheckBox_Changed"
                            Unchecked="AdminCheckBox_Changed">
                            <CheckBox.ToolTip>
                                <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                    <Bold>In-Game /ai Chat Commands</Bold><LineBreak/>
                                    Allows players to type /ai commands directly in game chat.<LineBreak/><LineBreak/>
                                    <Bold>Available commands:</Bold><LineBreak/>
                                    • /ai start - Enable auto-spawn<LineBreak/>
                                    • /ai stop - Disable auto-spawn<LineBreak/>
                                    • /ai spawn_for &lt;player&gt; &lt;species&gt; [count] - Spawn near a player<LineBreak/>
                                    • /ai spawn_corpse_for &lt;player&gt; &lt;species&gt; [count] - Spawn a dead dino near a player<LineBreak/>
                                    • /ai despawn - Remove all spawned AI<LineBreak/>
                                    • /ai kill - Kill all spawned AI<LineBreak/><LineBreak/>
                                    <Bold>Security:</Bold> When "Require Admin" is enabled below, only admins listed in Game.ini AdminsSteamIDs can use these commands.<LineBreak/><LineBreak/>
                                    <Bold>Note:</Bold> This Admin UI always works regardless of this setting (server owner access).
                                </TextBlock>
                            </CheckBox.ToolTip>
                        </CheckBox>

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,8,0,0"
                            VerticalAlignment="Center"
                            Text="Require Admin for /ai Commands"
                            ToolTip="When enabled, in-game /ai commands require admin authorization" />
                        <CheckBox
                            x:Name="chkRequireAdminForCommands"
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="0,8,0,0"
                            VerticalAlignment="Center"
                            Checked="AdminCheckBox_Changed"
                            Unchecked="AdminCheckBox_Changed">
                            <CheckBox.ToolTip>
                                <TextBlock MaxWidth="450" TextWrapping="Wrap">
                                    <Bold>Require Admin Authorization</Bold><LineBreak/>
                                    When enabled, only admins can use /ai chat commands.<LineBreak/><LineBreak/>
                                    <Bold>How it works:</Bold><LineBreak/>
                                    1. Mod parses TheIsle.log for player join messages<LineBreak/>
                                    2. Extracts Steam IDs from join logs<LineBreak/>
                                    3. Checks Steam ID against Game.ini AdminsSteamIDs<LineBreak/>
                                    4. Allows/denies command based on match<LineBreak/><LineBreak/>
                                    <Bold>Security:</Bold> Recommended to leave enabled. Prevents players from controlling AI spawns.<LineBreak/><LineBreak/>
                                    <Bold>Note:</Bold> This Admin UI bypasses this check (server owner always has access).
                                </TextBlock>
                            </CheckBox.ToolTip>
                        </CheckBox>

                        <!--  Log Parsing Settings  -->
                        <TextBlock
                            x:Name="lblAdminLogParseInterval"
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,16,0,0"
                            VerticalAlignment="Center"
                            Text="Log Parse Interval (min)"
                            ToolTip="How often to parse join log for Steam IDs" />
                        <TextBox
                            x:Name="txtAdminLogParseInterval"
                            Grid.Row="2"
                            Grid.Column="2"
                            Height="26"
                            Margin="0,16,0,0"
                            VerticalContentAlignment="Center"
                            ToolTip="How often to parse join log for Steam IDs (minutes, min 0.017 = 1 second). Higher values for bigger servers to reduce CPU usage." />

                        <TextBlock
                            x:Name="lblAdminLogParseMaxLines"
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0,8,0,0"
                            VerticalAlignment="Center"
                            Text="Log Parse Max Lines"
                            ToolTip="Maximum lines to parse per interval" />
                        <TextBox
                            x:Name="txtAdminLogParseMaxLines"
                            Grid.Row="3"
                            Grid.Column="2"
                            Height="26"
                            Margin="0,8,0,0"
                            VerticalContentAlignment="Center"
                            ToolTip="Maximum lines to parse per interval (min 100). Prevents lag spikes with large logs. 10000 is recommended for 400 player servers." />

                        <!--  Info Section  -->
                        <Border
                            Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Margin="0,16,0,0"
                            Padding="12"
                            Background="#1E1E1E"
                            BorderBrush="{StaticResource SecondaryTextBrush}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,8" FontWeight="SemiBold">How Admin Authorization Works:</TextBlock>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap">
                                    • Admin list is loaded from Game.ini AdminsSteamIDs every 60 seconds
                                </TextBlock>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap">
                                    • Join log is parsed to map player names to Steam IDs (configurable interval above)
                                </TextBlock>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap">
                                    • In-game /ai chat commands require players to be on the admin list
                                </TextBlock>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap">
                                    • Non-admin attempts are logged with "Access denied" message
                                </TextBlock>
                                <TextBlock
                                    Margin="0,0,0,4"
                                    Foreground="{StaticResource SecondaryTextBrush}"
                                    TextWrapping="Wrap">
                                    • Disable "Require Admin" to allow all players to use /ai commands
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!--  Server Admin List Section  -->
                    </Grid>
                </GroupBox>
            </TabItem>

            <TabItem Header="Status">
                <GroupBox
                    Margin="8"
                    Padding="10"
                    Header="Server Status">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="10" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="Last Command" />
                        <TextBox
                            x:Name="txtLastCommand"
                            Grid.Row="0"
                            Grid.Column="2"
                            Height="26"
                            VerticalContentAlignment="Center"
                            IsReadOnly="True" />

                        <Button
                            x:Name="btnRefreshStatus"
                            Grid.Row="0"
                            Grid.Column="3"
                            Width="90"
                            Margin="10,0,0,0"
                            Click="btnRefreshStatus_Click"
                            Content="Refresh"
                            ToolTip="Refresh status file from server" />

                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,8,0,0"
                            VerticalAlignment="Center"
                            Text="Last Updated" />
                        <TextBox
                            x:Name="txtLastUpdated"
                            Grid.Row="1"
                            Grid.Column="2"
                            Height="26"
                            Margin="0,8,0,0"
                            VerticalContentAlignment="Center"
                            IsReadOnly="True" />

                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,8,0,0"
                            VerticalAlignment="Center"
                            Text="Last Spawn" />
                        <TextBox
                            x:Name="txtLastSpawn"
                            Grid.Row="2"
                            Grid.Column="2"
                            Height="26"
                            Margin="0,8,0,0"
                            VerticalContentAlignment="Center"
                            IsReadOnly="True" />

                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0,12,0,0"
                            VerticalAlignment="Top"
                            Text="Counts" />
                        <TextBox
                            x:Name="txtStatusCounts"
                            Grid.Row="3"
                            Grid.Column="2"
                            Height="160"
                            Margin="0,10,0,356"
                            IsReadOnly="True"
                            TextWrapping="Wrap"
                            ToolTip="Per-species counts from the status file"
                            VerticalScrollBarVisibility="Auto" Grid.RowSpan="2" />
                    </Grid>
                </GroupBox>
            </TabItem>

        </TabControl>

        <StackPanel
            Grid.Row="2"
            Margin="0,12,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                x:Name="btnReload"
                Width="110"
                Margin="0,0,8,0"
                Click="btnReload_Click"
                Cursor="Hand"
                ToolTip="Reload config from disk and refresh the UI fields"
                ToolTipService.ShowOnDisabled="True">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource FluentIcon}"
                        Text="&#xE72C;" />
                    <TextBlock VerticalAlignment="Center" Text="Refresh Config" />
                </StackPanel>
            </Button>
            <Button
                x:Name="btnReset"
                Width="90"
                Margin="0,0,8,0"
                Click="btnReset_Click"
                Cursor="Hand"
                ToolTip="Reset all fields to defaults (not saved)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        Style="{StaticResource FluentIcon}"
                        Text="&#xE777;" />
                    <TextBlock VerticalAlignment="Center" Text="Reset" />
                </StackPanel>
            </Button>
            <Button
                x:Name="btnSave"
                Width="110"
                Click="btnSave_Click"
                Cursor="Hand"
                Style="{StaticResource PrimaryButton}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Margin="0,0,8,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style BasedOn="{StaticResource FluentIcon}" TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <Setter Property="Text" Value="&#xE74E;" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Dirty">
                                        <Setter Property="Text" Value="&#xE7BA;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                <Setter Property="Text" Value="Save" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=Button}}" Value="Dirty">
                                        <Setter Property="Text" Value="Save *" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Button>
        </StackPanel>

        <TextBlock
            x:Name="txtSaveStatus"
            Grid.Row="3"
            Margin="0,6,0,0"
            HorizontalAlignment="Right"
            FontSize="12"
            Foreground="{StaticResource SecondaryTextBrush}"
            Text="" />

    </Grid>
</Window>
